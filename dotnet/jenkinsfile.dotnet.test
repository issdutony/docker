pipeline {
    agent {
        label 'dind-agent'
    }

    options {
        lock(resource: "lock-${JOB_NAME}")
        disableConcurrentBuilds()
        skipDefaultCheckout()
        buildDiscarder(logRotator(numToKeepStr: '5', artifactNumToKeepStr: '5'))
    // timestamps()
    }

    environment {
        CACHE_DIR = "/home/jenkins/cache/${JOB_NAME}/.nuget/packages"
        SRC_DIR = '/home/jenkins/src/InventoryApp'
        PROJECT_PATH = 'InventoryApp.csproj' // 替換成你的方案或專案檔路徑
    }
    stages {
        stage('Restore') {
            steps {
                script {
                    def String dockerImage = 'rd/mcr.microsoft.com/dotnet/sdk:10.0'
                    def String dockerArgs = [
                        "-v ${SRC_DIR}:${SRC_DIR}",
                        "-v ${CACHE_DIR}:${CACHE_DIR}",
                        '--network host'
                    ].join(' ')

                    docker.image(dockerImage).inside(dockerArgs) {
                        sh '''
                        cp -a ${SRC_DIR}/. ${WORKSPACE}/
                        rm -rf **/obj **/bin
                        dotnet restore "${PROJECT_PATH}"
                        dotnet build "${PROJECT_PATH}" --configuration Release --no-restore
                        dotnet publish ${PROJECT_PATH} --configuration Release --no-build --output ./publish
                        '''

                        // withSonarQubeEnv('sonar-server') {
                        //     sh '''
                        //     dotnet tool install --global dotnet-sonarscanner
                        //     export PATH="$PATH:/root/.dotnet/tools"

                        //     cp -a ${SRC_DIR}/. ${WORKSPACE}/
                        //     rm -rf **/obj **/bin

                    //     dotnet-sonarscanner begin \
                    //         /k:"InventoryApp" \
                    //         /d:sonar.token="sqa_79189745226e17b22d9b0607b1b7cc071b520d06"
                    //     dotnet build ${PROJECT_PATH} --configuration Release --no-restore
                    //     dotnet-sonarscanner end /d:sonar.token="sqa_79189745226e17b22d9b0607b1b7cc071b520d06"
                    //     dotnet publish ${PROJECT_PATH} --configuration Release --output ./publish
                    //     '''
                    // }
                    }
                }
            }
        }

        stage('ArchiveArtifacts') {
            steps {
                archiveArtifacts artifacts: 'publish/**', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            // 無論構建是成功、失敗還是被中斷，最後都強制清理工作區 (cleanws)
            cleanWs()
        }
    }
}
